{
  "name": "travenest",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @travenest/web dev & pnpm --filter @travenest/api dev",
    "dev:web": "pnpm --filter @travenest/web dev",
    "dev:api": "pnpm --filter @travenest/api dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @travenest/web build",
    "build:api": "pnpm --filter @travenest/api build",
    "start": "pnpm -r start",
    "start:web": "pnpm --filter @travenest/web start",
    "start:api": "pnpm --filter @travenest/api start",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter @travenest/api test",
    "test:watch": "pnpm --filter @travenest/api test:watch",
    "test:coverage": "pnpm --filter @travenest/api test:coverage",
    "db:generate": "pnpm --filter @travenest/database generate",
    "db:push": "pnpm --filter @travenest/database push",
    "db:migrate": "pnpm --filter @travenest/database migrate",
    "db:migrate:deploy": "pnpm --filter @travenest/database migrate:deploy",
    "db:seed": "pnpm --filter @travenest/database seed",
    "db:backfill:content": "pnpm --filter @travenest/database backfill:content",
    "db:studio": "pnpm --filter @travenest/database studio",
    "clean": "rimraf node_modules apps/*/node_modules packages/*/node_modules apps/*/.next apps/*/dist packages/*/dist",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "rimraf": "^5.0.5",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@supabase/ssr": "github:supabase/ssr"
  }
}